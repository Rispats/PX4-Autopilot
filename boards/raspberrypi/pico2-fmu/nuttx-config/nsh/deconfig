// Architecture
CONFIG_ARCH_CHIP_RP2350=y
CONFIG_ARCH_CORTEXM33=y
CONFIG_ARCH_FPU=y
CONFIG_ARCH_DPFPU=n                    # RP2350 = single precision only
CONFIG_ARCH_TOOLCHAIN_GNU=y


// Dual Core
CONFIG_SMP=y
CONFIG_SMP_NCPUS=2


// Peripherals
CONFIG_RP2350_SPI0=y                   # IMU
CONFIG_RP2350_SPI1=y                   # SD card
CONFIG_RP2350_I2C0=y                   # BMP280
CONFIG_RP2350_I2C1=y                   # HMC5883
CONFIG_RP2350_UART0=y                  # Telem/NSH
CONFIG_RP2350_UART1=y                  # PX4IO
CONFIG_RP2350_PIO_UART=y               # GPS via PIO
CONFIG_RP2350_PWM=y                    # RGB LED PWM slices
CONFIG_RP2350_ADC=y                    # Battery voltage on GP28


// Baud rates
CONFIG_UART0_BAUD=57600
CONFIG_UART1_BAUD=1500000
CONFIG_UART0_SERIAL_CONSOLE=n          # console is USB, not UART0
CONFIG_UART1_SERIAL_CONSOLE=n          # console is USB CDC, not UART1

// SD Card
CONFIG_MMCSD=y
CONFIG_MMCSD_SPI=y                     # SPI mode SD on SPI1
CONFIG_FS_FAT=y
CONFIG_FAT_LFN=y
CONFIG_NSH_ARCHINIT=y                  # triggers board_app_initialize SD mount


// Mavlink and NSH console
CONFIG_USBDEV=y
CONFIG_CDCACM=y
CONFIG_CDCACM_CONSOLE=y                # NSH console on USB CDC (/dev/ttyACM0)
CONFIG_DRIVERS_CDCACM_AUTOSTART=y      # brings up /dev/ttyACM0 at boot automatically

CONFIG_SYSTEMCMDS_NSHTERM=y            # allows 'nshterm /dev/ttyS0' at runtime
CONFIG_NSH_USBCONSOLE=y                # NSH primary console = USB CDC
CONFIG_NSH_USBCONDEV="/dev/ttyACM0"
CONFIG_NSH_ARCHINIT=y                  # runs board_app_initialize before NSH starts

CONFIG_MODULES_MAVLINK=y


// LED PWM
CONFIG_PWM=y
CONFIG_DRIVERS_PWM=n                   # PX4 actuator PWM — IO owns this


// NUttX HEAP
CONFIG_MM_REGIONS=2                    # RP2350 has two SRAM banks
CONFIG_RAM_SIZE=524288                 # 512KB usable (leave 8KB for core1 stack)
CONFIG_RAM_START=0x20000000

// Memory
CONFIG_BOARD_CONSTRAINED_FLASH=y
CONFIG_BOARD_CONSTRAINED_MEMORY=y
CONFIG_SCHED_WORKQUEUE=y
CONFIG_SCHED_HPWORK=y
CONFIG_SCHED_LPWORK=y
CONFIG_HPWORK_STACKSIZE=2048           # reduce from default 4096
CONFIG_IDLETHREAD_STACKSIZE=1024